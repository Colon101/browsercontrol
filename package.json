{
  "name": "browsercontrol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:agent && npm run build:extension && npm run build:settings",
    "build:agent": "node ./scripts/build-agent.mjs",
    "build:extension": "node ./apps/extension-firefox/build.mjs",
    "build:settings": "node ./apps/settings-ui/build.mjs",
    "dev": "node --import tsx ./apps/agent/src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.6.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "esbuild": "^0.25.9",
    "fflate": "^0.8.2",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
